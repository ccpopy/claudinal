{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claudinal",
  "version": "0.2.3",
  "identifier": "com.claudinal.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "splash",
        "title": "Claudinal",
        "url": "claudinal-startup://localhost/",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "resizable": false,
        "center": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "backgroundColor": "#f7f8ff"
      },
      {
        "label": "main",
        "title": "Claudinal",
        "create": false,
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "focus": false,
        "center": true,
        "backgroundColor": "#f7f8ff"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "app", "dmg", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Claude Code 桌面外壳",
    "longDescription": "Claudinal 是 Claude Code CLI 的桌面外壳，提供流式对话、会话管理与可视化设置。",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["SimpChinese", "English"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRBRDNGNzU3ODJFMDY4QUYKUldTdmFPQ0NWL2ZUU3FoYW0zTUQ3bUVPbzBuRHVWQm5NZC9KcjkyVitkRnBhN25aeWZHbFpoR2YK",
      "endpoints": [
        "https://github.com/ccpopy/claudinal/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
